{
  "name": "lek_sticker",
  "version": "1.3.0",
  "main": "index.js",
  "scripts": {
    "dev": "mkdir -p .next/static/development .next/server && concurrently -n \"next,warmup\" -c \"cyan,yellow\" \"NODE_OPTIONS='--max-old-space-size=4096' next dev --turbopack\" \"node scripts/dev-warmup.mjs\"",
    "dev:clean": "rm -rf .next && mkdir -p .next/static/development .next/server && concurrently -n \"next,warmup\" -c \"cyan,yellow\" \"NODE_OPTIONS='--max-old-space-size=4096' next dev --turbopack\" \"node scripts/dev-warmup.mjs\"",
    "typecheck": "tsc --noEmit",
    "build": "next build",
    "start": "next start",
    "tunnel": "ngrok http 3000",
    "dev:tunnel": "concurrently -n \"next,ngrok\" -c \"cyan,green\" \"next dev\" \"ngrok http 3000\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/recharts": "^1.8.29",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.5.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "typescript": "^6.0.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
